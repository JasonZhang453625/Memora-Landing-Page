const libraryLines = [
  { icon: Search, text: '标题、标签、摘要和来源统一搜索' },
  { icon: FolderOpen, text: '文件夹、嵌套文件夹和来源筛选保留手动控制' },
  { icon: Workflow, text: '处理失败进入进程页，不丢失已保存链接' },
  { icon: ShieldCheck, text: 'API Key 不进入备份，索引可重建' },
];

const chatLines = [
  '先从本地索引召回相关摘要',
  '模型只基于候选摘要回答',
  '引用编号映射回真实 articleId',
  '信息不足时明确拒绝编造',
