const differentiators = [
  {
    icon: Globe2,
    title: '跨平台低摩擦收集',
    body: '从微信、小红书、知乎、Bilibili、X、YouTube 和普通网页直接接收链接。',
  },
  {
    icon: Library,
    title: '仿生记忆提取',
    body: '不是保存整页噪声，而是提取标题、关键观点、标签和原文入口。',
  },
  {
    icon: BrainCircuit,
    title: '联想式全库召回',
    body: '不要求先创建资料集，直接向全部已知识化内容提问。',
  },
  {
    icon: LockKeyhole,
    title: '本地优先与 BYOK',
    body: '核心数据在本机，AI 请求直连用户配置的 OpenAI-compatible 服务。',
  },
  {
    icon: Network,
    title: 'Agent-friendly 记忆包',
