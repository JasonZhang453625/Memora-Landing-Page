const flow = [
  { icon: Send, title: '一键分享', text: '微信、知乎、Bilibili、小红书、X、YouTube 等来源统一进入。' },
  { icon: Sparkles, title: '仿生提取', text: '过滤平台噪声，只保留标题、关键观点、标签与原文入口。' },
  { icon: Database, title: '本地记忆', text: '知识卡片、标签、索引和处理状态保存在设备本地。' },
  { icon: FileText, title: '追溯原文', text: '每次回答都能回到引用知识卡片和原始页面。' },
