---
import '../styles/global.css';
import {
  Apple,
  Archive,
  ArrowDownToLine,
  ArrowRight,
  Bot,
  Boxes,
  BrainCircuit,
  CheckCircle2,
  Compass,
  Database,
  FileText,
  FolderOpen,
  Globe2,
  KeyRound,
  Library,
  LockKeyhole,
  MessageSquareText,
  Network,
  Search,
  Send,
  ShieldCheck,
  Sparkles,
  Tags,
  Workflow,
} from '@lucide/astro';

const downloadUrl = 'https://github.com/JasonZhang453625/Article-Hub/releases/download/v2.0.15/app-release.apk';
const productName = '记忆海';
const productNameEn = 'Memora';

const notes = [
  {
    source: 'Web',
    color: '#00AEEF',
    time: '7h ago',
    title: 'Attention Is All You Need',
    body: '只提取关键观点、标签与原文入口，压缩成可再次召回的记忆单元。',
  },
  {
    source: 'X',
    color: '#0F172A',
    time: 'just now',
    title: 'X 平台讨论：本地 AI 记忆流',
    body: '从一条链接进入记忆海，自动完成知识化、标签与本地索引。',
  },
  {
    source: 'WeChat',
    color: '#09B83E',
    time: '2d ago',
    title: '端侧索引与个人记忆资产',
    body: '保存后先落地，再处理；失败也会留在进程页等待重试，不丢记忆。',
  },
  {
    source: 'Bilibili',
    color: '#FB7299',
    time: '1d ago',
    title: '长视频观点如何变成知识卡片',
    body: '把分散内容变成高密度知识颗粒，后续可以直接联想检索。',
  },
  {
    source: 'Rednote',
    color: '#FF355D',
    time: '3h ago',
    title: '个人记忆如何被整理',
    body: '弱结构自动完成，强结构仍保留给用户控制。',
  },
  {
    source: 'YouTube',
    color: '#FF0033',
    time: '5h ago',
    title: 'AI Agents 研究清单',
    body: '每个回答都必须回到真实卡片和原文入口。',
  },
  {
    source: 'ChatGPT',
    color: '#10A37F',
    time: '4d ago',
    title: 'OKF 是什么？',
    body: '导出的记忆包可被其他 Memora 实例或外部 Agent 消费。',
  },
  {
    source: 'Zhihu',
    color: '#1677FF',
    time: '6d ago',
    title: '为什么收藏很少被再次使用',
    body: '语义召回解决只记得概念、不记得标题的问题。',
  },
  {
    source: 'Reddit',
    color: '#FF5700',
    time: '9d ago',
    title: 'Local-first memory tools',
    body: '数据、索引和处理状态保存在设备本地，AI 请求直连用户服务。',
  },
  {
    source: 'PDF',
    color: '#7C8A98',
    time: 'soon',
    title: '研究资料与原文追溯',
    body: '记忆卡片不是事实终点，原文始终保留用于核实。',
  },
